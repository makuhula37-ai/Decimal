<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Decimal Places Mastery | Form One Mathematics</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #1e2b3c 0%, #0f1a24 100%);
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* main lesson card */
        .lesson-container {
            max-width: 1300px;
            width: 100%;
            background: #fef9e8;
            background-image: radial-gradient(circle at 10% 20%, rgba(255,245,215,0.6) 2%, transparent 2.5%);
            background-size: 28px 28px;
            border-radius: 3rem;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255,245,190,0.3);
            overflow: hidden;
            transition: all 0.2s;
        }

        /* header with timer & motivational bar */
        .hero {
            background: #2c5a6e;
            padding: 1.2rem 2rem;
            color: white;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            gap: 15px;
            border-bottom: 6px solid #ffb74d;
        }

        .title h1 {
            font-size: 1.8rem;
            letter-spacing: -0.5px;
            font-weight: 700;
        }

        .title p {
            font-size: 0.9rem;
            opacity: 0.85;
            margin-top: 5px;
        }

        .timer-box {
            background: #0e2a32;
            padding: 8px 20px;
            border-radius: 60px;
            text-align: center;
            box-shadow: inset 0 1px 3px rgba(0,0,0,0.3), 0 4px 8px rgba(0,0,0,0.1);
        }

        .timer-label {
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 1px;
        }

        .timer-display {
            font-size: 2.2rem;
            font-weight: 800;
            font-family: monospace;
            line-height: 1;
            color: #ffd966;
        }

        /* main grid: left -> theory & place value demo, right -> interactive */
        .two-columns {
            display: flex;
            flex-wrap: wrap;
            gap: 1.8rem;
            padding: 2rem 2rem 2rem 2rem;
        }

        .theory-card {
            flex: 1.2;
            min-width: 260px;
            background: #ffffffdd;
            backdrop-filter: blur(2px);
            background: white;
            border-radius: 2rem;
            padding: 1.5rem;
            box-shadow: 0 12px 20px rgba(0, 0, 0, 0.08);
            transition: transform 0.2s;
        }

        .interactive-card {
            flex: 1.8;
            min-width: 320px;
            background: white;
            border-radius: 2rem;
            padding: 1.5rem;
            box-shadow: 0 12px 20px rgba(0, 0, 0, 0.08);
        }

        .section-title {
            font-size: 1.6rem;
            font-weight: 700;
            border-left: 8px solid #f4a261;
            padding-left: 18px;
            margin-bottom: 1.2rem;
            color: #1e3b44;
        }

        .place-table {
            background: #f1f8fc;
            border-radius: 1.5rem;
            overflow-x: auto;
            margin: 1.2rem 0;
        }

        .place-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            font-weight: bold;
            border-bottom: 2px solid #cbdbe6;
        }

        .grid-header {
            background: #457b9d;
            color: white;
            padding: 10px 5px;
            font-size: 0.8rem;
        }

        .grid-value {
            background: #e9f0f5;
            padding: 12px 5px;
            font-family: monospace;
            font-size: 1.2rem;
            font-weight: 600;
            color: #1f4e6e;
        }

        .example-number {
            background: #ffefdb;
            border-radius: 2rem;
            padding: 0.9rem;
            text-align: center;
            margin: 1rem 0;
            font-size: 1.4rem;
            font-family: monospace;
            font-weight: bold;
            color: #b45116;
        }

        /* interactive quiz area */
        .question-area {
            background: #eef4fa;
            border-radius: 1.8rem;
            padding: 1.4rem;
            margin-bottom: 1.8rem;
        }

        .question-text {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 1rem;
            background: white;
            padding: 12px 18px;
            border-radius: 40px;
            display: inline-block;
            width: 100%;
            box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        }

        .options {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin: 20px 0 15px;
        }

        .opt-btn {
            background: white;
            border: 2px solid #2c5a6e;
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            color: #1e3b44;
            flex: 1 0 auto;
            text-align: center;
        }

        .opt-btn:hover {
            background: #ffdead;
            transform: scale(0.97);
            border-color: #f4a261;
        }

        .feedback {
            margin: 15px 0 10px;
            padding: 10px;
            border-radius: 30px;
            font-weight: 500;
            text-align: center;
        }

        .correct-feedback {
            background: #c8f0d1;
            color: #0f5323;
            border-left: 8px solid #2e7d32;
        }

        .wrong-feedback {
            background: #ffe0db;
            color: #b13e3e;
            border-left: 8px solid #c62828;
        }

        .score-area {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            margin-top: 10px;
            margin-bottom: 20px;
            background: #d9e3ec;
            padding: 12px 18px;
            border-radius: 60px;
        }

        .score-badge {
            font-size: 1.3rem;
            font-weight: 800;
            background: #2c5a6e;
            padding: 4px 15px;
            border-radius: 32px;
            color: white;
        }

        .next-btn {
            background: #f4a261;
            border: none;
            padding: 12px 24px;
            font-weight: bold;
            font-size: 1.1rem;
            border-radius: 60px;
            cursor: pointer;
            color: #2d3e40;
            transition: 0.1s linear;
            width: 100%;
            box-shadow: 0 4px 0 #c76e2e;
        }

        .next-btn:active {
            transform: translateY(2px);
            box-shadow: 0 1px 0 #c76e2e;
        }

        .next-btn:disabled {
            background: #bbada0;
            transform: none;
            cursor: not-allowed;
            box-shadow: none;
        }

        .mini-chart {
            font-size: 0.9rem;
            margin-top: 20px;
            background: #fff3e0;
            padding: 12px;
            border-radius: 1.2rem;
        }

        hr {
            margin: 12px 0;
            border-color: #ffd96655;
        }

        @media (max-width: 780px) {
            .two-columns {
                padding: 1rem;
            }
            .timer-display {
                font-size: 1.6rem;
            }
            .title h1 {
                font-size: 1.3rem;
            }
        }
        button {
            font-family: inherit;
        }
        .highlight {
            background: #ffd966 !important;
            transition: 0.1s;
        }
    </style>
</head>
<body>

<div class="lesson-container" id="app">
    <div class="hero">
        <div class="title">
            <h1>📐 Decimal Places · Form One Masterclass</h1>
            <p>⭐ Understand tenths, hundredths, thousandths & place values | 30 min session</p>
        </div>
        <div class="timer-box">
            <div class="timer-label">⏱️ LESSON TIMER</div>
            <div class="timer-display" id="timerDisplay">30:00</div>
        </div>
    </div>

    <div class="two-columns">
        <!-- LEFT COLUMN: teaching resources -->
        <div class="theory-card">
            <div class="section-title">📖 Decimal Places Explained</div>
            <p style="margin-bottom: 1rem; line-height:1.4;">Digits after the decimal point have <strong>place values</strong>:</p>
            <div class="place-table">
                <div class="place-grid">
                    <div class="grid-header">Tenths</div>
                    <div class="grid-header">Hundredths</div>
                    <div class="grid-header">Thousandths</div>
                    <div class="grid-header">10‑Thousandths</div>
                    <div class="grid-header">100‑Thousandths</div>
                    <div class="grid-header">Millionths</div>
                    <div class="grid-header">...</div>
                </div>
                <div class="place-grid">
                    <div class="grid-value">0.1</div>
                    <div class="grid-value">0.01</div>
                    <div class="grid-value">0.001</div>
                    <div class="grid-value">0.0001</div>
                    <div class="grid-value">0.00001</div>
                    <div class="grid-value">0.000001</div>
                    <div class="grid-value">more</div>
                </div>
            </div>
            <div class="example-number">
                🧮 Example: 3 . 1 4 1 5 <br>
                <span style="font-size:1rem;">3 → Units | 1 → Tenths | 4 → Hundredths | 1 → Thousandths | 5 → Ten‑Thousandths</span>
            </div>
            <div class="mini-chart">
                💡 <strong>Key fact:</strong> The first decimal place is <strong>tenths</strong> (1/10). <br>
                Second place = hundredths (1/100). Third = thousandths (1/1000). <br>
                To read: <strong>0.34</strong> = thirty-four hundredths. <strong>7.205</strong> = seven and two hundred five thousandths.
            </div>
            <hr>
            <div class="mini-chart">
                🎯 <strong>Rounding tip:</strong> To round to 2 decimal places, look at the 3rd decimal digit (thousandths). If it's 5 or more, round up!
            </div>
        </div>

        <!-- RIGHT COLUMN: interactive quiz & practice -->
        <div class="interactive-card">
            <div class="section-title">🧠 Quick Challenge Zone</div>
            <div class="question-area" id="quizArea">
                <div class="question-text" id="questionText">Loading question...</div>
                <div id="optionsContainer" class="options"></div>
                <div id="feedbackMsg" class="feedback"></div>
                <div class="score-area">
                    <span>🏆 Your score:</span>
                    <span class="score-badge" id="scoreValue">0</span>
                    <span>✔️ Answered: <span id="answeredCount">0</span> / <span id="totalQuestionsSpan">10</span></span>
                </div>
                <button id="nextQuestionBtn" class="next-btn">➡️ Next Challenge</button>
            </div>
            <div style="margin-top: 20px; background:#fcf2e1; border-radius: 1.2rem; padding: 12px; font-size:0.9rem;">
                ⭐ <strong>30‑minute learning flow:</strong> Read left side rules → attempt 10 interactive decimal questions → repeat incorrect ones. <br>
                ✅ Master: identifying place values (tenths, hundredths, thousandths), decimal digits, and conversion from words.
            </div>
        </div>
    </div>
</div>

<script>
    // ---------- TIMER LOGIC (30 minutes = 1800 seconds) ----------
    let totalSeconds = 30 * 60;   // 1800 secs
    const timerDisplay = document.getElementById('timerDisplay');
    let timerInterval = null;
    
    function formatTime(secs) {
        const mins = Math.floor(secs / 60);
        const remainSecs = secs % 60;
        return `${mins.toString().padStart(2, '0')}:${remainSecs.toString().padStart(2, '0')}`;
    }
    
    function updateTimerUI() {
        timerDisplay.innerText = formatTime(totalSeconds);
        if(totalSeconds <= 0) {
            clearInterval(timerInterval);
            timerDisplay.innerText = "00:00";
            // optional: show message but not block interaction
            const fb = document.getElementById('feedbackMsg');
            if(fb) fb.innerHTML = "⏰ Time's up! But you can still continue practicing. Great effort!";
        }
    }
    
    function startTimer() {
        if(timerInterval) clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            if(totalSeconds > 0) {
                totalSeconds--;
                updateTimerUI();
            } else {
                clearInterval(timerInterval);
            }
        }, 1000);
    }
    
    // ---------- QUESTION BANK (decimal place value, digits, identification) ----------
    // 15 questions to give variety, we'll cycle through first 10 for the "active set" but we can rotate, 
    // but to keep consistent we will have 10 distinct question objects, after finishing 10, you can "restart" or show completion.
    // We'll define a set of 12 questions, store index, and allow "next" to go through 10 mandatory, but show completion afterwards.
    // also provide reset or repeat.
    
    const questionBank = [
        { text: "In the number 45.873, which digit is in the HUNDREDTHS place?", options: ["8", "7", "3", "4"], correct: "7", explanation: "Hundredths is the second digit after decimal: 45.87 → 7 is hundredths." },
        { text: "What is the value of the digit 5 in 92.065?", options: ["5 tenths", "5 hundredths", "5 thousandths", "5 units"], correct: "5 thousandths", explanation: "Decimal: 92.065 → 5 is in the thousandths place (0.005)." },
        { text: "Write 'thirty-four hundredths' as a decimal.", options: ["0.34", "0.034", "3.4", "34.0"], correct: "0.34", explanation: "Thirty-four hundredths = 34/100 = 0.34." },
        { text: "In 7.1052, what is the THOUSANDTHS place digit?", options: ["1", "0", "5", "2"], correct: "5", explanation: "7.1052 → digits: tenths:1, hundredths:0, thousandths:5, ten-thousandths:2" },
        { text: "Round 12.876 to two decimal places.", options: ["12.88", "12.87", "12.9", "12.80"], correct: "12.88", explanation: "Look at third decimal digit (6) >=5, so hundredths digit 7 becomes 8 → 12.88" },
        { text: "Which decimal has the digit 4 in the thousandths place?", options: ["0.384", "0.438", "0.843", "4.382"], correct: "0.384", explanation: "0.384 : tenths=3, hundredths=8, thousandths=4 ✅" },
        { text: "How do you write 'seven and two hundred five thousandths'?", options: ["7.205", "7.025", "7.25", "7.2005"], correct: "7.205", explanation: "Seven = 7, two hundred five thousandths = 205/1000 = 0.205 → 7.205" },
        { text: "Identify the tenths digit in 893.046", options: ["0", "4", "6", "9"], correct: "0", explanation: "893.046 : digit after decimal: 0 (tenths), 4 hundredths, 6 thousandths." },
        { text: "What is 0.5 + 0.25 in decimal? (concept check)", options: ["0.75", "0.30", "0.075", "0.755"], correct: "0.75", explanation: "0.5 = 0.50, 0.50+0.25=0.75 (place value addition)." },
        { text: "Which digit holds the hundred-thousandths place in 8.64391?", options: ["6", "4", "9", "1"], correct: "9", explanation: "Digits: 6(tenths),4(hundredths),3(thousandths),9(ten-thousandths),1(hundred-thousandths)" },
        { text: "Write 5/1000 as a decimal.", options: ["0.005", "0.05", "0.5", "5.0"], correct: "0.005", explanation: "5 thousandths = 0.005" },
        { text: "In the decimal 0.082, the digit 8 is in which place?", options: ["Tenths", "Hundredths", "Thousandths", "Units"], correct: "Hundredths", explanation: "0.082 → tenths:0 , hundredths:8, thousandths:2" }
    ];
    
    // We'll use first 10 questions for a focused 30-minute session. But we can allow full set if students finish – show more.
    let currentQuestions = [...questionBank]; // take all 12, but we can control total count as 12.
    let currentIndex = 0;
    let score = 0;
    let answered = 0;
    let quizLocked = false;      // after answering a question, lock until next pressed
    let currentQuestionObj = null;
    let selectedAnswer = null;
    
    // DOM elements
    const questionTextEl = document.getElementById('questionText');
    const optionsContainer = document.getElementById('optionsContainer');
    const feedbackMsg = document.getElementById('feedbackMsg');
    const scoreValueSpan = document.getElementById('scoreValue');
    const answeredCountSpan = document.getElementById('answeredCount');
    const totalQuestionsSpan = document.getElementById('totalQuestionsSpan');
    const nextBtn = document.getElementById('nextQuestionBtn');
    
    // total number of questions we will rotate (all from bank, we can repeat at the end)
    let totalQuestionCount = currentQuestions.length;  // 12
    
    totalQuestionsSpan.innerText = totalQuestionCount;
    
    function updateScoreUI() {
        scoreValueSpan.innerText = score;
        answeredCountSpan.innerText = answered;
    }
    
    function loadQuestion() {
        // remove lock
        quizLocked = false;
        selectedAnswer = null;
        // clear feedback styles
        feedbackMsg.innerHTML = '';
        feedbackMsg.className = 'feedback';
        // get question based on currentIndex, but if we reach beyond length, we either reset or show finish message.
        if(currentIndex >= totalQuestionCount) {
            // all questions completed! Show final mastery note and allow restart
            questionTextEl.innerText = "🎉 Amazing! You've completed all decimal challenges! 🎉";
            optionsContainer.innerHTML = `<div style="text-align:center; padding:20px;">🌟 Great work! Refresh or press 'Restart Session' below to practice more. 🌟</div>`;
            nextBtn.innerText = "🔄 Restart Session";
            // remove old behavior, we'll attach restart
            nextBtn.onclick = () => resetQuiz();
            return;
        }
        
        currentQuestionObj = currentQuestions[currentIndex];
        questionTextEl.innerText = currentQuestionObj.text;
        // render options
        optionsContainer.innerHTML = '';
        currentQuestionObj.options.forEach(opt => {
            const btn = document.createElement('button');
            btn.innerText = opt;
            btn.className = 'opt-btn';
            btn.addEventListener('click', () => handleAnswer(opt, btn));
            optionsContainer.appendChild(btn);
        });
        // reset next button text and behaviour (if not in finish mode)
        nextBtn.innerText = "➡️ Next Challenge";
        nextBtn.disabled = false;
        // remove old onclick if overwritten
        nextBtn.onclick = () => nextQuestionHandler();
    }
    
    function handleAnswer(selected, btnElement) {
        if(quizLocked) {
            feedbackMsg.innerHTML = "⏳ You already answered! Click 'Next Challenge' to continue.";
            feedbackMsg.className = "feedback wrong-feedback";
            return;
        }
        if(!currentQuestionObj) return;
        const isCorrect = (selected === currentQuestionObj.correct);
        // lock quiz
        quizLocked = true;
        selectedAnswer = selected;
        
        // highlight all option buttons visually (optional)
        const allBtns = document.querySelectorAll('.opt-btn');
        allBtns.forEach(btn => {
            btn.style.cursor = 'default';
            if(btn.innerText === currentQuestionObj.correct) {
                btn.style.background = "#c8e6c9";
                btn.style.borderColor = "#2e7d32";
            }
            if(btn.innerText === selected && !isCorrect) {
                btn.style.background = "#ffcdd2";
                btn.style.borderColor = "#c62828";
            }
            btn.disabled = true;
        });
        
        if(isCorrect) {
            score++;
            feedbackMsg.innerHTML = `✅ Correct! ${currentQuestionObj.explanation || "Well done!"}`;
            feedbackMsg.className = "feedback correct-feedback";
        } else {
            feedbackMsg.innerHTML = `❌ Oops! The correct answer is "${currentQuestionObj.correct}". ${currentQuestionObj.explanation}`;
            feedbackMsg.className = "feedback wrong-feedback";
        }
        answered++;
        updateScoreUI();
    }
    
    function nextQuestionHandler() {
        if(!quizLocked && currentIndex < totalQuestionCount) {
            // if not answered yet, and not completed, advise to answer first
            if(currentIndex < totalQuestionCount) {
                feedbackMsg.innerHTML = "⚠️ Please select an answer before moving to the next question!";
                feedbackMsg.className = "feedback wrong-feedback";
                return;
            }
        }
        // move to next index
        if(currentIndex < totalQuestionCount) {
            currentIndex++;
            loadQuestion();
        } else {
            // if already finished or if we need to restart (handled inside loadQuestion)
            if(currentIndex >= totalQuestionCount) {
                resetQuiz();
            } else {
                loadQuestion();
            }
        }
    }
    
    function resetQuiz() {
        // full reset of progress but keep the same question set
        currentIndex = 0;
        score = 0;
        answered = 0;
        quizLocked = false;
        selectedAnswer = null;
        updateScoreUI();
        // reshuffle maybe not needed, but we keep same set order for consistency, but we keep all questions as they are.
        // Reset any disabled states
        loadQuestion();
        feedbackMsg.innerHTML = "🔄 Quiz restarted! Let's ace those decimal places!";
        feedbackMsg.className = "feedback correct-feedback";
        setTimeout(() => {
            if(feedbackMsg.innerHTML.includes("restarted")) feedbackMsg.innerHTML = "";
        }, 2000);
    }
    
    // initial load
    function init() {
        startTimer();
        loadQuestion();
        updateScoreUI();
    }
    
    // Also add an extra hint: on window load ensure timer starts
    window.addEventListener('load', init);
    
    // optional small adaptive: if student attempts to revisit, keep timer working seamlessly
    // Also provide a small interactive place-value tooltip inside left column? Already included.
    // Additionally we can add an interactive decimal builder if needed but it's full.
    
    // For better teaching: add live hover effect in place table, but not needed. 
    // Also ensure that after finishing the whole set, they can restart.
    // Provide nice rounding example in left column also.
    
    // Bonus: dynamic highlight for decimal demonstration (adding a little extra to left column block)
    const decimalExampleDiv = document.querySelector('.example-number');
    if(decimalExampleDiv) {
        decimalExampleDiv.addEventListener('click', () => {
            decimalExampleDiv.style.transform = "scale(1.01)";
            setTimeout(() => { decimalExampleDiv.style.transform = ""; }, 200);
        });
    }
    
    // No timer stop on finish, but they can keep practicing forever, respecting 30-min learning.
    // If timer reaches zero, we show note but no blocking.
    
    // optional improvement: display remaining time message.
    function warnTimeLow() {
        if(totalSeconds <= 60 && totalSeconds > 0) {
            const timerBox = document.querySelector('.timer-box');
            if(timerBox && !timerBox.classList.contains('time-low')) {
                timerBox.style.animation = "pulse 1s infinite";
                const styleSheet = document.createElement("style");
                styleSheet.textContent = `@keyframes pulse { 0% { opacity:1; background:#0e2a32; } 50% { opacity:0.8; background:#a5581c; } 100% { opacity:1; background:#0e2a32; } }`;
                document.head.appendChild(styleSheet);
                timerBox.classList.add('time-low');
            }
        }
    }
    // monitor timer seconds by interval in timer
    const originalInterval = setInterval;
    // we can override but safe: just add hook inside timer tick.
    const origSetInterval = setInterval;
    // we'll add extra monitor inside timer interval.
    // but timer already exists: modify it to call warnTimeLow
    const timerHook = setInterval(() => {
        if(totalSeconds <= 60 && totalSeconds > 0) warnTimeLow();
        if(totalSeconds === 0) {
            const fb = document.getElementById('feedbackMsg');
            if(fb && !fb.innerText.includes("Time's up")) {
                fb.innerHTML = "⏰ 30 minutes completed! Keep practicing — you're building strong decimal skills!";
                fb.classList.add("feedback");
            }
        }
    }, 1000);
    // just a minor keep-alive
    window.timerHook = timerHook;
</script>
</body>
</html>
